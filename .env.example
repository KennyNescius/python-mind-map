# Environment variables for the Netlify "save-content" function.
# Set these in Netlify (Site settings -> Environment variables), NOT in a local
# .env file — the editor's save flow runs server-side on Netlify.

# GitHub Personal Access Token (fine-grained) with Contents: Read and write
# on this repository. Used by the function to commit public/content.json.
GITHUB_TOKEN="github_pat_..."

# Target repository in "owner/name" form.
GITHUB_REPO="KennyNescius/python-mind-map"

# Branch the editor commits to (optional, defaults to "main").
GIT_BRANCH="main"
